# Template only — copy to .env for local dev (never commit .env)
# cp apps/mobile/.env.example apps/mobile/.env
# Or copy from web: cp apps/web/.env.local apps/mobile/.env and rename vars to EXPO_PUBLIC_*

# Web API base (run: pnpm --filter web dev locally, or production URL)
EXPO_PUBLIC_APP_URL=http://localhost:3000

# Supabase (anon key only — from Supabase dashboard → API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Sanity (read-only; most content loads via web API anyway)
EXPO_PUBLIC_SANITY_PROJECT_ID=7hl877lg
EXPO_PUBLIC_SANITY_DATASET=production
